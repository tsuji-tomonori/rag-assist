{
  "name": "@memorag-mvp/contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./infra": {
      "types": "./infra.d.ts",
      "import": "./src/infra.ts"
    },
    "./access-control": {
      "types": "./access-control.d.ts",
      "import": "./src/access-control.ts",
      "require": "./src/access-control.ts"
    },
    "./rag-quality-control": {
      "types": "./rag-quality-control.d.ts",
      "import": "./src/rag-quality-control.ts",
      "require": "./src/rag-quality-control.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.14",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
