{
  "name": "@memorag-mvp/infra",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle",
    "bundle": "node scripts/bundle-lambdas.mjs",
    "synth:yaml": "mkdir -p cdk.out && cdk synth > cdk.out/MemoRagMvpStack.template.yaml",
    "test": "npm run bundle && node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cdk": "cdk",
    "check:dynamodb-gsi-update-limit": "node --import tsx scripts/check-dynamodb-gsi-update-limit.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1041.0",
    "@aws-sdk/client-dynamodb": "^3.1039.0",
    "@aws-sdk/client-s3vectors": "^3.1024.0",
    "@memorag-mvp/contract": "0.1.0",
    "aws-cdk-lib": "^2.190.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.15.0",
    "aws-cdk": "^2.190.0",
    "cdk-nag": "^2.38.2",
    "esbuild": "^0.25.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
