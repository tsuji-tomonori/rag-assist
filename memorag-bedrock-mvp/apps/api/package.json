{
  "name": "@memorag-mvp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "start": "tsx src/local.ts",
    "docs:openapi": "tsx src/generate-openapi-docs.ts",
    "docs:openapi:check": "tsx src/validate-openapi-docs.ts",
    "test": "tsx --test src/**/*.test.ts src/**/**/*.test.ts",
    "test:coverage": "c8 --check-coverage --statements 90 --branches 0 --functions 90 --lines 90 --reporter=text-summary --reporter=json-summary tsx --test src/**/*.test.ts src/**/**/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "@aws-sdk/client-codebuild": "^3.1045.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1041.0",
    "@aws-sdk/client-dynamodb": "^3.1039.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-s3vectors": "^3.1024.0",
    "@aws-sdk/client-sfn": "^3.1041.0",
    "@aws-sdk/client-textract": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@hono/node-server": "^1.19.0",
    "@hono/zod-openapi": "^0.19.0",
    "@langchain/core": "^1.1.42",
    "dotenv": "^16.4.7",
    "hono": "^4.10.0",
    "jose": "^5.10.0",
    "mammoth": "^1.9.0",
    "pdf-parse": "^1.1.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.15.0",
    "c8": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
