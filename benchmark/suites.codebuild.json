      "dataset": { "source": "codebuild-input" },
      "corpus": {
        "source": "codebuild-bucket",
        "dir": "./benchmark/.runner-mtrag-corpus",
        "suiteId": "mtrag-v1",
        "s3Prefix": "corpus/conversation/mtrag-v1"
      }
    },
    {
      "suiteId": "chatrag-bench-v1",
      "mode": "agent",
      "runner": "conversation",
      "metadata": { "useCase": "chat_rag", "datasetName": "chatrag-bench", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": {
        "source": "codebuild-bucket",
        "dir": "./benchmark/.runner-chatrag-bench-corpus",
        "suiteId": "chatrag-bench-v1",
        "s3Prefix": "corpus/conversation/chatrag-bench-v1"
      }
    },
    {
      "suiteId": "jp-public-pdf-qa-v1",
      "mode": "agent",
