{
  "version": 1,
  "defaults": {
    "dataset": "./benchmark/.runner-dataset.jsonl",
    "output": "./benchmark/.runner-results.jsonl",
    "summary": "./benchmark/.runner-summary.json",
    "report": "./benchmark/.runner-report.md"
  },
  "suites": [
    {
      "suiteId": "smoke-agent-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "internal_qa", "datasetName": "smoke-agent", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": { "dir": "benchmark/corpus/standard-agent-v1", "suiteId": "standard-agent-v1" }
    },
    {
      "suiteId": "standard-agent-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "internal_qa", "datasetName": "standard-agent", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": { "dir": "benchmark/corpus/standard-agent-v1", "suiteId": "standard-agent-v1" }
    },
    {
      "suiteId": "clarification-smoke-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "internal_qa", "datasetName": "clarification-smoke", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": { "dir": "benchmark/corpus/standard-agent-v1", "suiteId": "standard-agent-v1" }
    },
    {
      "suiteId": "search-smoke-v1",
      "mode": "search",
      "runner": "search",
      "metadata": { "useCase": "search_retrieval", "datasetName": "search-smoke", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": { "dir": "benchmark/corpus/standard-agent-v1", "suiteId": "standard-agent-v1" }
    },
    {
      "suiteId": "search-standard-v1",
      "mode": "search",
      "runner": "search",
      "metadata": { "useCase": "search_retrieval", "datasetName": "search-standard", "datasetVersion": "v1", "conversionVersion": "manifest-v1" },
      "dataset": { "source": "codebuild-input" },
      "corpus": { "dir": "benchmark/corpus/standard-agent-v1", "suiteId": "standard-agent-v1" }
    },
    {
      "suiteId": "allganize-rag-evaluation-ja-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "internal_qa", "datasetName": "allganize-rag-evaluation-ja", "datasetVersion": "v1", "conversionVersion": "converter-v1" },
      "dataset": { "source": "prepare" },
      "prepare": {
        "script": "prepare:allganize-ja",
        "env": {
          "ALLGANIZE_RAG_DATASET_OUTPUT": "${DATASET}",
          "ALLGANIZE_RAG_CORPUS_DIR": "./benchmark/.runner-allganize-corpus",
          "BENCHMARK_CORPUS_DIR": "./benchmark/.runner-allganize-corpus"
        }
      }
    },
    {
      "suiteId": "mmrag-docqa-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "long_pdf_qa", "datasetName": "mmlongbench-docqa", "datasetVersion": "v1", "conversionVersion": "converter-v1" },
      "dataset": { "source": "prepare" },
      "corpus": { "suiteId": "mmrag-docqa-v1" },
      "prepare": {
        "script": "prepare:mmrag-docqa",
        "env": {
          "MMRAG_DOCQA_DATASET_OUTPUT": "${DATASET}",
          "MMRAG_DOCQA_CORPUS_DIR": "./benchmark/.runner-mmrag-docqa-corpus",
          "BENCHMARK_CORPUS_DIR": "./benchmark/.runner-mmrag-docqa-corpus"
        }
      }
    },
    {
      "suiteId": "mtrag-v1",
      "mode": "agent",
      "runner": "conversation",
