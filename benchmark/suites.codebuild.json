      "prepare": {
        "script": "prepare:jp-public-pdf-qa",
        "env": {
          "JP_PUBLIC_PDF_QA_DATASET_OUTPUT": "${DATASET}",
          "JP_PUBLIC_PDF_QA_CORPUS_DIR": "./benchmark/.runner-jp-public-pdf-qa-corpus",
          "BENCHMARK_CORPUS_DIR": "./benchmark/.runner-jp-public-pdf-qa-corpus"
        }
      }
    },
    {
      "suiteId": "mlit-pdf-figure-table-rag-seed-v1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "knowledge_quality", "datasetName": "mlit-pdf-figure-table-rag", "datasetVersion": "v1", "conversionVersion": "converter-v1" },
      "dataset": { "source": "prepare" },
      "corpus": { "suiteId": "mlit-pdf-figure-table-rag-seed-v1" },
      "prepare": {
        "script": "prepare:mlit-pdf-figure-table-rag",
        "env": {
          "MLIT_PDF_RAG_DATASET_OUTPUT": "${DATASET}",
          "MLIT_PDF_RAG_CORPUS_DIR": "./benchmark/.runner-mlit-pdf-figure-table-rag-corpus",
          "BENCHMARK_CORPUS_DIR": "./benchmark/.runner-mlit-pdf-figure-table-rag-corpus"
        }
      }
    },
    {
      "suiteId": "architecture-drawing-qarag-v0.1",
      "mode": "agent",
      "runner": "agent",
      "metadata": { "useCase": "design_drawing_qa", "datasetName": "architecture-drawing-qarag", "datasetVersion": "v0.1", "conversionVersion": "converter-v1" },
      "dataset": { "source": "prepare" },
      "corpus": { "suiteId": "architecture-drawing-qarag-v0.1" },
      "prepare": {
        "script": "prepare:architecture-drawing-qarag",
        "env": {
          "ARCHITECTURE_QARAG_DATASET_OUTPUT": "${DATASET}",
          "ARCHITECTURE_QARAG_CORPUS_DIR": "./benchmark/.runner-architecture-drawing-corpus",
